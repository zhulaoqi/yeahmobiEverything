<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.yeahmobi.everything.ui.AdminController"
      spacing="0">

    <!-- Page header -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <padding><Insets top="24" right="24" bottom="16" left="24"/></padding>
        <Label text="🔧 管理端" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="createSkillButton" text="+ 创建 Skill" styleClass="btn-primary"
                onAction="#onCreateSkill"/>
        <Button fx:id="manageKnowledgeButton" text="📚 知识库管理" styleClass="btn-secondary"
                onAction="#onManageKnowledge"/>
        <TextField fx:id="skillRepoInput" promptText="Skills 仓库地址或本地路径（如 https://github.com/anthropics/skills）"
                   prefWidth="420"/>
        <Button fx:id="importAnthropicButton" text="导入 Skill 仓库" styleClass="btn-secondary"
                onAction="#onImportAnthropicSkills"/>
    </HBox>

    <!-- Tab pane for Skill management and Feedback -->
    <TabPane fx:id="adminTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <padding><Insets top="0" right="24" bottom="24" left="24"/></padding>

        <!-- Skill Management Tab -->
        <Tab text="Skill 管理">
            <VBox spacing="12">
                <padding><Insets top="16" right="0" bottom="0" left="0"/></padding>

                <VBox spacing="8">
                    <Label text="管理员权限" styleClass="card-title"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="promoteUserInput" promptText="输入用户ID或邮箱"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="promoteUserButton" text="设为管理员" styleClass="btn-primary"
                                onAction="#onPromoteUser"/>
                        <Label fx:id="promoteUserResultLabel" text="" managed="false" visible="false"/>
                    </HBox>
                </VBox>

                <Separator/>

                <!-- Command line integration area -->
                <VBox spacing="8">
                    <Label text="命令行集成" styleClass="card-title"/>
                    <TextArea fx:id="commandInput" promptText='--name "名称" --desc "描述" --category "分类" --icon "图标" --type GENERAL|INTERNAL --prompt "Prompt模板"'
                              styleClass="text-area" wrapText="true" prefRowCount="3"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="executeCommandButton" text="执行命令" styleClass="btn-primary"
                                onAction="#onExecuteCommand"/>
                        <Label fx:id="commandResultLabel" text="" managed="false" visible="false"/>
                    </HBox>
                </VBox>

                <Separator/>

                <!-- Skill list -->
                <Label text="已集成 Skill 列表" styleClass="card-title"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                    <VBox fx:id="skillListContainer" spacing="8"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- Feedback Tab -->
        <Tab text="反馈管理">
            <VBox spacing="12">
                <padding><Insets top="16" right="0" bottom="0" left="0"/></padding>
                <Label text="用户反馈列表（时间倒序）" styleClass="card-title"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                    <VBox fx:id="feedbackListContainer" spacing="8"/>
                </ScrollPane>
            </VBox>
        </Tab>

        <!-- Personal Skill Review Tab -->
        <Tab text="个人 Skill 审核">
            <VBox spacing="12">
                <padding><Insets top="16" right="0" bottom="0" left="0"/></padding>
                <Label text="待审核个人 Skill（私有提交）" styleClass="card-title"/>
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                    <VBox fx:id="personalSkillListContainer" spacing="8"/>
                </ScrollPane>
            </VBox>
        </Tab>
    </TabPane>
</VBox>
