<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
  Standalone register view.
  In the default flow, registration is handled inline within login.fxml
  via the registerContainer toggle. This file is provided for cases where
  the register form needs to be loaded as a separate scene.
-->
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.yeahmobi.everything.ui.RegisterController"
           prefWidth="480" prefHeight="520"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="16">
        <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

        <Label text="创建账号" styleClass="login-form-title"/>
        <Label text="注册 Yeahmobi Everything 账号" styleClass="login-form-subtitle"/>

        <Region prefHeight="8"/>

        <VBox spacing="12" alignment="CENTER" maxWidth="320">
            <TextField fx:id="regEmailField" promptText="邮箱地址"
                       styleClass="text-input" maxWidth="320"/>

            <!-- Verification code row -->
            <HBox spacing="8" alignment="CENTER" maxWidth="320">
                <TextField fx:id="regCodeField" promptText="验证码"
                           styleClass="text-input" HBox.hgrow="ALWAYS"/>
                <Button fx:id="sendCodeBtn" text="发送验证码"
                        styleClass="btn-secondary" onAction="#onSendCode"
                        minWidth="100"/>
            </HBox>

            <PasswordField fx:id="regPasswordField" promptText="设置密码"
                           styleClass="text-input" maxWidth="320"/>
            <PasswordField fx:id="regConfirmPasswordField" promptText="确认密码"
                           styleClass="text-input" maxWidth="320"
                           onAction="#onRegister"/>

            <Button fx:id="registerBtn" text="注册"
                    styleClass="btn-primary" onAction="#onRegister"
                    maxWidth="320" prefHeight="36"/>
        </VBox>

        <!-- Error message -->
        <Label fx:id="registerErrorLabel" text="" styleClass="login-error-label"
               wrapText="true" maxWidth="320" managed="false" visible="false"/>

        <!-- Loading indicator -->
        <ProgressIndicator fx:id="registerProgress" prefWidth="24" prefHeight="24"
                           managed="false" visible="false"/>

        <Region prefHeight="8"/>

        <!-- Back to login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="已有账号？" styleClass="login-hint-text"/>
            <Hyperlink fx:id="backToLoginLink" text="返回登录"
                       styleClass="login-link" onAction="#onBackToLogin"/>
        </HBox>
    </VBox>
</StackPane>
