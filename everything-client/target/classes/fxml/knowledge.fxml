<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.yeahmobi.everything.ui.KnowledgeController"
      spacing="0">

    <!-- Page header -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <padding><Insets top="24" right="24" bottom="16" left="24"/></padding>
        <Button fx:id="backButton" text="← 返回" styleClass="btn-secondary"
                onAction="#onBack"/>
        <Label fx:id="pageTitle" text="📚 知识库管理" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="uploadButton" text="+ 上传文件" styleClass="btn-primary"
                onAction="#onUploadFile"/>
        <Button fx:id="manualInputButton" text="✏ 手动输入" styleClass="btn-secondary"
                onAction="#onManualInput"/>
    </HBox>

    <Separator/>

    <!-- Main content area - StackPane for switching between list and edit views -->
    <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

        <!-- File list view -->
        <VBox fx:id="fileListView" spacing="12" managed="true" visible="true">
            <padding><Insets top="16" right="24" bottom="24" left="24"/></padding>

            <!-- Status / info bar -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label fx:id="fileCountLabel" text="共 0 个知识库文件" styleClass="section-subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel" text="" managed="false" visible="false"/>
            </HBox>

            <!-- File list -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox fx:id="fileListContainer" spacing="8"/>
            </ScrollPane>
        </VBox>

        <!-- Manual input / edit view -->
        <ScrollPane fx:id="editView" fitToWidth="true" managed="false" visible="false" styleClass="scroll-pane">
            <VBox spacing="16">
                <padding><Insets top="24" right="60" bottom="24" left="60"/></padding>

                <Label fx:id="editTitle" text="手动输入知识内容"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2328;"/>
                <Label fx:id="editSubtitle" text="直接输入知识内容（如 FAQ、流程手册等）。"
                       styleClass="section-subtitle"/>

                <!-- Title field -->
                <VBox spacing="4">
                    <Label fx:id="editTitleLabel" text="标题 *" styleClass="card-title"/>
                    <TextField fx:id="editTitleField" promptText="请输入知识条目标题" styleClass="text-input"/>
                </VBox>

                <!-- Content field -->
                <VBox spacing="4">
                    <Label fx:id="editContentLabel" text="内容 *" styleClass="card-title"/>
                    <TextArea fx:id="editContentField" promptText="在此输入知识内容..."
                              styleClass="text-area" wrapText="true" prefRowCount="15"/>
                </VBox>

                <!-- Validation error -->
                <Label fx:id="editValidationError" text="" styleClass="login-error-label"
                       managed="false" visible="false"/>

                <!-- Action buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <padding><Insets top="8"/></padding>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="editCancelButton" text="取消" styleClass="btn-secondary"
                            onAction="#onEditCancel"/>
                    <Button fx:id="editSaveButton" text="保存" styleClass="btn-primary"
                            onAction="#onEditSave"/>
                </HBox>
            </VBox>
        </ScrollPane>

    </StackPane>
</VBox>
