<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yeahmobi.everything.ui.AuthController"
            styleClass="login-root window-root">

    <!-- Custom window bar -->
    <top>
        <HBox fx:id="windowBar" styleClass="window-bar" alignment="CENTER_LEFT" prefHeight="32">
            <padding><Insets top="6" right="12" bottom="6" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="windowCloseBtn" text="×" styleClass="window-btn, window-btn-close"
                        onAction="#onWindowClose"/>
                <Button fx:id="windowMinBtn" text="–" styleClass="window-btn, window-btn-min"
                        onAction="#onWindowMinimize"/>
                <Button fx:id="windowMaxBtn" text="+" styleClass="window-btn, window-btn-max"
                        onAction="#onWindowMaximize"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <StackPane styleClass="login-canvas">
            <!-- Centered single-column layout (GitHub style) -->
            <VBox alignment="TOP_CENTER" spacing="16" maxWidth="360">
                <padding><Insets top="72" right="0" bottom="40" left="0"/></padding>

        <!-- App icon (Polar Bear Logo) -->
        <ImageView fitWidth="64" fitHeight="64" preserveRatio="true" smooth="true">
            <Image url="@../images/app-icon.png"/>
        </ImageView>

        <!-- ====== Login form container (shown by default) ====== -->
            <VBox fx:id="loginContainer" alignment="CENTER" spacing="0"
              managed="true" visible="true" maxWidth="360">

            <!-- Title -->
            <Label text="登录 Everything" styleClass="login-heading"/>
            <Region prefHeight="24"/>

            <!-- Form card -->
            <VBox styleClass="login-card" spacing="16">

                <!-- Email field with label -->
                <VBox spacing="6">
                    <Label text="邮箱地址" styleClass="login-field-label"/>
                    <TextField fx:id="emailField" styleClass="text-input" maxWidth="Infinity"/>
                </VBox>

                <!-- Password field with label -->
                <VBox spacing="6">
                    <Label text="密码" styleClass="login-field-label"/>
                    <PasswordField fx:id="passwordField" styleClass="text-input"
                                   maxWidth="Infinity" onAction="#onEmailLogin"/>
                </VBox>

                <!-- Sign in button -->
                <Button fx:id="emailLoginBtn" text="登录"
                        styleClass="btn-primary, login-btn" onAction="#onEmailLogin"
                        maxWidth="Infinity" prefHeight="36"/>

                <!-- Error message -->
                <Label fx:id="loginErrorLabel" text="" styleClass="login-error-label"
                       wrapText="true" managed="false" visible="false"/>

                <!-- Loading indicator -->
                <ProgressIndicator fx:id="loginProgress" prefWidth="24" prefHeight="24"
                                   managed="false" visible="false"/>
            </VBox>

            <Region prefHeight="16"/>

            <!-- Divider with "or" -->
            <HBox alignment="CENTER" spacing="12">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="Or" styleClass="login-divider-text"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region prefHeight="16"/>

            <!-- Feishu login (outlined card style) -->
            <VBox styleClass="login-card" spacing="0" alignment="CENTER">
                <Button fx:id="feishuLoginBtn" text="使用飞书登录"
                        styleClass="btn-feishu, login-btn, login-btn-outline" onAction="#onFeishuLogin"
                        maxWidth="Infinity" prefHeight="36"/>
            </VBox>

            <Region prefHeight="16"/>

            <!-- Register link (bottom card) -->
            <VBox styleClass="login-card" alignment="CENTER" spacing="0">
                <HBox alignment="CENTER" spacing="4">
                    <Label text="还没有账号？" styleClass="login-hint-text"/>
                    <Hyperlink fx:id="registerLink" text="立即注册"
                               styleClass="login-link" onAction="#onShowRegister"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ====== Register form container (hidden by default) ====== -->
            <VBox fx:id="registerContainer" alignment="CENTER" spacing="0"
              managed="false" visible="false" maxWidth="360">

            <!-- Title -->
            <Label text="创建你的账号" styleClass="login-heading"/>
            <Region prefHeight="20"/>

            <!-- Form card -->
            <VBox styleClass="login-card" spacing="16">

                <!-- Email -->
                <VBox spacing="6">
                    <Label text="邮箱地址" styleClass="login-field-label"/>
                    <TextField fx:id="regEmailField" styleClass="text-input" maxWidth="Infinity"/>
                </VBox>

                <!-- Verification code -->
                <VBox spacing="6">
                    <Label text="验证码" styleClass="login-field-label"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="regCodeField" styleClass="text-input"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="sendCodeBtn" text="发送"
                                styleClass="btn-secondary" onAction="#onSendCode"
                                minWidth="72"/>
                    </HBox>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="密码" styleClass="login-field-label"/>
                    <PasswordField fx:id="regPasswordField" styleClass="text-input"
                                   maxWidth="Infinity"/>
                </VBox>

                <!-- Confirm password -->
                <VBox spacing="6">
                    <Label text="确认密码" styleClass="login-field-label"/>
                    <PasswordField fx:id="regConfirmPasswordField" styleClass="text-input"
                                   maxWidth="Infinity" onAction="#onRegister"/>
                </VBox>

                <!-- Register button -->
                <Button fx:id="registerBtn" text="注册"
                        styleClass="btn-primary, login-btn" onAction="#onRegister"
                        maxWidth="Infinity" prefHeight="36"/>

                <!-- Register error -->
                <Label fx:id="registerErrorLabel" text="" styleClass="login-error-label"
                       wrapText="true" managed="false" visible="false"/>

                <!-- Register loading -->
                <ProgressIndicator fx:id="registerProgress" prefWidth="24" prefHeight="24"
                                   managed="false" visible="false"/>
            </VBox>

            <Region prefHeight="16"/>

            <!-- Back to login (bottom card) -->
            <VBox styleClass="login-card" alignment="CENTER" spacing="0">
                <HBox alignment="CENTER" spacing="4">
                    <Label text="已有账号？" styleClass="login-hint-text"/>
                    <Hyperlink fx:id="backToLoginLink" text="返回登录"
                               styleClass="login-link" onAction="#onShowLogin"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Footer -->
        <Region VBox.vgrow="ALWAYS"/>
        <HBox alignment="CENTER" spacing="16">
            <Label text="Yeahmobi Everything" styleClass="login-footer-text"/>
        </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
