<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yeahmobi.everything.ui.ChatController"
            styleClass="chat-root">

    <!-- Top: 简洁头部 -->
    <top>
        <HBox fx:id="chatHeaderBar" styleClass="chat-header" spacing="8" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
            <Label fx:id="skillNameLabel" text="Skill 名称" styleClass="chat-skill-name"/>
            <Label fx:id="skillTypeBadge" text="" styleClass="card-badge-internal"
                   managed="false" visible="false"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="clearHistoryBtn" text="清空对话" styleClass="chat-header-action"
                    onAction="#onClearHistory"/>
            <Button fx:id="howToBtn" text="如何使用" styleClass="chat-header-action"
                    onAction="#onToggleHowTo"/>
            <Button fx:id="usageGuideBtn" text="使用说明" styleClass="chat-header-action"
                    onAction="#onShowUsageGuide"/>
            <Button fx:id="exportBtn" text="导出最近输出" styleClass="chat-header-action"
                    onAction="#onExportResult"/>
        </HBox>
    </top>

    <!-- Center: 聊天消息区域 -->
    <center>
        <VBox spacing="0">
            <!-- Skill “如何使用”面板（优先展示本地化说明） -->
            <VBox fx:id="skillHowToPanel" spacing="8" managed="false" visible="false" styleClass="skill-howto-panel">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="如何使用" styleClass="step-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="hideHowToBtn" text="收起" styleClass="chat-header-action"
                            onAction="#onToggleHowTo"/>
                </HBox>

                <VBox spacing="4" styleClass="step-card">
                    <Label text="适用场景" styleClass="step-title"/>
                    <Label fx:id="howToScenariosLabel" text="" wrapText="true" styleClass="step-body"/>
                </VBox>

                <VBox spacing="4" styleClass="step-card">
                    <Label text="你需要提供的信息" styleClass="step-title"/>
                    <Label fx:id="howToChecklistLabel" text="" wrapText="true" styleClass="step-body"/>
                </VBox>

                <VBox spacing="6" styleClass="step-card">
                    <Label text="示例（点击一键填入）" styleClass="step-title"/>
                    <HBox fx:id="howToExamplesRow" spacing="8" alignment="CENTER_LEFT"/>
                    <Label fx:id="howToOutputFormatLabel" text="" wrapText="true" styleClass="step-body"/>
                </VBox>
            </VBox>

            <VBox fx:id="stepPanel" spacing="8" managed="false" visible="false" styleClass="step-panel">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <VBox fx:id="planStepBox" spacing="4" styleClass="step-card">
                    <Label text="计划" styleClass="step-title"/>
                    <Label fx:id="planContent" text="" wrapText="true" styleClass="step-body"/>
                </VBox>
                <VBox fx:id="executionStepBox" spacing="4" styleClass="step-card">
                    <Label text="执行" styleClass="step-title"/>
                    <Label fx:id="executionContent" text="" wrapText="true" styleClass="step-body"/>
                </VBox>
                <VBox fx:id="reviewStepBox" spacing="4" styleClass="step-card">
                    <Label text="审阅" styleClass="step-title"/>
                    <Label fx:id="reviewContent" text="" wrapText="true" styleClass="step-body"/>
                </VBox>
            </VBox>

            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" styleClass="scroll-pane"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="messagesContainer" spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                </VBox>
            </ScrollPane>

            <HBox fx:id="marketplaceActionBar" spacing="8" alignment="CENTER_RIGHT"
                  managed="false" visible="false">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <Button fx:id="useSkillBtn" text="进入聊天使用技能" styleClass="btn-primary, market-use-skill-btn"
                        onAction="#onUseSkillNow"/>
            </HBox>
        </VBox>
    </center>

    <!-- Bottom: 微信风格 - 可拖动分割线 + 输入区 -->
    <bottom>
        <VBox spacing="0">
            <!-- 可拖动的分割线 -->
            <Region fx:id="inputDivider" styleClass="chat-input-divider" prefHeight="1" minHeight="1" maxHeight="1"/>
            
            <!-- 输入区 -->
            <VBox fx:id="inputArea" styleClass="chat-input-area" spacing="0" prefHeight="150" minHeight="80" maxHeight="400">
                <!-- Loading -->
                <HBox fx:id="loadingBox" spacing="8" alignment="CENTER_LEFT"
                      managed="false" visible="false">
                    <padding><Insets top="6" right="16" bottom="2" left="16"/></padding>
                    <ProgressIndicator fx:id="loadingIndicator" prefWidth="16" prefHeight="16"/>
                    <Label fx:id="loadingLabel" text="AI 正在思考中..." styleClass="chat-loading-text"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="stopBtn" text="停止" styleClass="chat-header-action"
                            onAction="#onStopGenerating"/>
                </HBox>

                <!-- Error -->
                <Label fx:id="errorLabel" text="" styleClass="chat-error-text"
                       managed="false" visible="false" wrapText="true">
                    <padding><Insets top="4" right="16" bottom="4" left="16"/></padding>
                </Label>

                <!-- 工具栏 -->
                <HBox fx:id="chatToolbar" styleClass="chat-toolbar" spacing="2" alignment="CENTER_LEFT">
                    <padding><Insets top="6" right="12" bottom="4" left="12"/></padding>
                    <Button fx:id="attachFileBtn" text="" styleClass="chat-tool-btn"
                            onAction="#onAttachFile" contentDisplay="GRAPHIC_ONLY"/>
                </HBox>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="0" right="12" bottom="4" left="12"/></padding>
                    <Label text="快捷提醒" styleClass="section-subtitle"/>
                    <ChoiceBox fx:id="quickReminderDayChoice" prefWidth="86"/>
                    <ChoiceBox fx:id="quickReminderTimeChoice" prefWidth="94"/>
                    <ChoiceBox fx:id="quickReminderLeadChoice" prefWidth="92"/>
                    <Button fx:id="quickReminderCreateBtn" text="一键创建提醒"
                            styleClass="attachment-summary-action-btn"
                            onAction="#onQuickCreateReminder"/>
                </HBox>

                <ScrollPane fx:id="attachmentStrip" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            managed="false" visible="false" styleClass="attachment-strip">
                    <content>
                        <HBox fx:id="attachmentRow" spacing="6" styleClass="attachment-row">
                            <padding><Insets top="2" right="12" bottom="4" left="12"/></padding>
                        </HBox>
                    </content>
                </ScrollPane>

                <VBox fx:id="attachmentBatchSummaryBox" managed="false" visible="false"
                      styleClass="attachment-summary-box">
                    <padding><Insets top="2" right="12" bottom="4" left="12"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label fx:id="attachmentBatchSummaryLabel" text="" wrapText="true"
                               styleClass="attachment-summary-label" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="attachmentSummaryToggleBtn" text="展开明细"
                                styleClass="chat-header-action"
                                onAction="#onToggleAttachmentSummaryDetail"/>
                    </HBox>
                    <HBox fx:id="attachmentSummaryActionRow" alignment="CENTER_LEFT" spacing="8">
                        <Button fx:id="attachmentAnomalyFilterBtn" text="仅看异常项"
                                styleClass="attachment-summary-action-btn"
                                onAction="#onToggleAttachmentAnomalyOnly"/>
                        <Button fx:id="attachmentCopyAnomalyBtn" text="复制异常清单"
                                styleClass="attachment-summary-action-btn"
                                onAction="#onCopyAttachmentAnomalyList"/>
                        <Button fx:id="attachmentExportSummaryBtn" text="导出结构化摘要"
                                styleClass="attachment-summary-action-btn"
                                onAction="#onExportAttachmentStructuredSummary"/>
                    </HBox>
                    <Label fx:id="attachmentBatchDetailLabel" text="" wrapText="true"
                           managed="false" visible="false"
                           styleClass="attachment-summary-detail-label"/>
                </VBox>

                <!-- 输入区 - 全域输入框，Enter发送 -->
                <TextArea fx:id="messageInput" promptText="输入消息... (Enter 发送, Shift+Enter 换行)"
                          styleClass="chat-message-input" wrapText="true" VBox.vgrow="ALWAYS">
                    <VBox.margin><Insets top="0" right="8" bottom="8" left="8"/></VBox.margin>
                </TextArea>

                <!-- sendBtn hidden, kept for backward compatibility -->
                <Button fx:id="sendBtn" text="发送" onAction="#onSend"
                        managed="false" visible="false"/>
            </VBox>
        </VBox>
    </bottom>

</BorderPane>
