<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yeahmobi.everything.ui.MainController"
            prefWidth="1200" prefHeight="760"
            minWidth="900" minHeight="640"
            styleClass="window-root">

    <!-- Custom window bar -->
    <top>
        <HBox fx:id="windowBar" styleClass="window-bar" alignment="CENTER_LEFT" prefHeight="32">
            <padding><Insets top="6" right="12" bottom="6" left="12"/></padding>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="windowCloseBtn" text="×" styleClass="window-btn, window-btn-close"
                        onAction="#onWindowClose"/>
                <Button fx:id="windowMinBtn" text="–" styleClass="window-btn, window-btn-min"
                        onAction="#onWindowMinimize"/>
                <Button fx:id="windowMaxBtn" text="+" styleClass="window-btn, window-btn-max"
                        onAction="#onWindowMaximize"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <!-- Left Sidebar -->
    <left>
        <VBox fx:id="navBar" styleClass="sidebar" spacing="4">
            <padding><Insets top="16" right="0" bottom="16" left="0"/></padding>

            <!-- Navigation Items -->
            <Button fx:id="navSkills" text="技能中心" styleClass="sidebar-item, sidebar-item-active"
                    onAction="#onNavSkills" maxWidth="Infinity"/>
            <Button fx:id="navMarket" text="技能市场" styleClass="sidebar-item"
                    onAction="#onNavMarket" maxWidth="Infinity"/>
            <Button fx:id="navHistory" text="历史记录" styleClass="sidebar-item"
                    onAction="#onNavHistory" maxWidth="Infinity"/>
            <Button fx:id="navFavorites" text="我的收藏" styleClass="sidebar-item"
                    onAction="#onNavFavorites" maxWidth="Infinity"/>
            <Button fx:id="navPersonalSkills" text="个人 Skill" styleClass="sidebar-item"
                    onAction="#onNavPersonalSkills" maxWidth="Infinity"/>
            <Button fx:id="navFeedback" text="反馈建议" styleClass="sidebar-item"
                    onAction="#onNavFeedback" maxWidth="Infinity"/>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Separator -->
            <Separator styleClass="divider"/>

            <!-- Settings & Admin -->
            <Button fx:id="navSettings" text="个人设置" styleClass="sidebar-item"
                    onAction="#onNavSettings" maxWidth="Infinity"/>
            <Button fx:id="navAdmin" text="管理后台" styleClass="sidebar-item"
                    onAction="#onNavAdmin" maxWidth="Infinity"/>
            <Button fx:id="navLogout" text="退出登录" styleClass="sidebar-item"
                    onAction="#onNavLogout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- Right Content Area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Pages are loaded dynamically here -->
            <Label text="欢迎使用 Yeahmobi Everything" styleClass="section-subheading"/>
        </StackPane>
    </center>

</BorderPane>
