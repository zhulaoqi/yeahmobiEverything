<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.yeahmobi.everything.ui.SkillController"
            fitToWidth="true" styleClass="scroll-pane">

    <VBox spacing="20">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <!-- Search bar -->
        <TextField fx:id="searchField" promptText="搜索技能..."
                   styleClass="search-field" maxWidth="Infinity"
                   onKeyReleased="#onSearchChanged"/>

        <!-- Type filter: 全部 / 通用 / 内部 -->
        <HBox fx:id="typeFilterBar" spacing="8" alignment="CENTER_LEFT">
            <Button fx:id="typeAllBtn" text="全部" styleClass="filter-tag-active"
                    onAction="#onFilterTypeAll"/>
            <Button fx:id="typeGeneralBtn" text="通用" styleClass="filter-tag"
                    onAction="#onFilterTypeGeneral"/>
            <Button fx:id="typeInternalBtn" text="内部" styleClass="filter-tag"
                    onAction="#onFilterTypeInternal"/>
        </HBox>

        <!-- Category filter tags -->
        <HBox fx:id="categoryFilterBar" spacing="8" alignment="CENTER_LEFT">
            <Label text="分类:" styleClass="section-subtitle"/>
        </HBox>


        <!-- Loading indicator -->
        <ProgressIndicator fx:id="loadingIndicator" prefWidth="32" prefHeight="32"
                           managed="false" visible="false"/>

        <!-- Error label with retry -->
        <HBox fx:id="errorBox" spacing="8" alignment="CENTER_LEFT" managed="false" visible="false">
            <Label fx:id="errorLabel" text="" styleClass="login-error-label" wrapText="true"/>
            <Button fx:id="retryBtn" text="重试" styleClass="btn-secondary" onAction="#onRetry"/>
        </HBox>

        <!-- Favorites section -->
        <VBox fx:id="favoritesSection" spacing="8" managed="false" visible="false">
            <Label text="我的收藏" styleClass="section-title"/>
            <FlowPane fx:id="favoritesPane" hgap="12" vgap="12"/>
        </VBox>

        <!-- Recently used section -->
        <VBox fx:id="recentSection" spacing="8" managed="false" visible="false">
            <Label text="最近使用" styleClass="section-title"/>
            <FlowPane fx:id="recentPane" hgap="12" vgap="12"/>
        </VBox>

        <!-- All skills section -->
        <VBox spacing="8">
            <Label fx:id="allSkillsTitle" text="全部技能" styleClass="section-title"/>
            <FlowPane fx:id="skillsPane" hgap="12" vgap="12"/>

            <!-- Empty state -->
            <VBox fx:id="emptyStateBox" spacing="8" alignment="CENTER"
                  managed="false" visible="false" styleClass="empty-state">
                <Label text="暂无可用技能" styleClass="empty-state-title"/>
                <Label text="请检查数据库连接或联系管理员导入技能" styleClass="empty-state-subtitle"/>
                <Button text="刷新列表" styleClass="btn-secondary" onAction="#onRetry"/>
            </VBox>
        </VBox>

        <!-- Spacer at bottom -->
        <Region prefHeight="24"/>
    </VBox>
</ScrollPane>
